# ── Ports ────────────────────────────────────────────────────────────────────
# External port the web UI is served on (default: 8000)
PORT=8000

# Internal port the WhatsApp bot API listens on
BOT_PORT=3001

# ── Internal service URLs ─────────────────────────────────────────────────────
# Docker Compose overrides these automatically — no need to change them here
BOT_API_URL=http://localhost:3001
PYTHON_API_URL=http://localhost:8000

# Public URL of the backend, used as the OAuth redirect URI for Google Photos.
# Only set this if accessing from a remote machine (e.g. Raspberry Pi on LAN).
# Example: BACKEND_PUBLIC_URL=http://192.168.1.42:8000
BACKEND_PUBLIC_URL=http://localhost:8000

# ── Data directory ────────────────────────────────────────────────────────────
# Where to store the database, face embeddings, and matched photos.
# Docker Compose pins this to /app/data — change only for native installs.
DATA_DIR=./data
